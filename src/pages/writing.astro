---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout
	title="Writing | HealthAI Notes"
	description="Writing index for HealthAI Notes covering documentation, workflow, and AI governance."
>
	<main class="page">
		<section class="page-section">
			<p class="eyebrow">Writing</p>
			<h1>Published notes and essays.</h1>
			<p class="lede">
				The writing section now runs from Markdown posts in an Astro content collection, so new
				pieces can be added without hand-editing route files.
			</p>
		</section>

		<section class="grid">
			{
				posts.map((post) => (
					<article class="card">
						<span>{post.data.heroTag}</span>
						<h2>{post.data.title}</h2>
						<p class="muted">{post.data.description}</p>
						<p class="muted">Published {post.data.pubDate.toLocaleDateString('en-US')}</p>
						<div class="actions">
							<a class="primary" href={`/writing/${post.id}/`}>Read Post</a>
						</div>
					</article>
				))
			}
		</section>
	</main>
</Layout>
