---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contact | HealthAI Notes"
	description="Contact and collaboration details for HealthAI Notes."
>
	<main class="page">
		<section class="page-section">
			<p class="eyebrow">Contact</p>
			<h1>Contact and collaboration.</h1>
			<p class="lede">
				This site does not need a complex contact flow yet. Start with the repo and add a direct
				email or scheduling link once you want active outreach.
			</p>
			<div class="actions">
				<a class="primary" href="https://github.com/healthai-notes/healthai-notes.github.io">
					GitHub Repository
				</a>
			</div>
		</section>

		<section class="two-up">
			<article class="page-section">
				<p class="kicker">Suggested Next Step</p>
				<h2>Add your real contact channel</h2>
				<p class="muted">
					Replace the placeholder with your email address, LinkedIn profile, or a booking link
					once you are ready to receive inbound messages.
				</p>
			</article>
			<article class="page-section">
				<p class="kicker">Topics</p>
				<ul class="list">
					<li>Clinical workflow and operations</li>
					<li>Documentation automation and coding support</li>
					<li>Evaluation, governance, and procurement</li>
				</ul>
			</article>
		</section>
	</main>
</Layout>
