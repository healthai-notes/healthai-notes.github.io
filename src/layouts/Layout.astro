---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'HealthAI Notes',
	description = 'Practical writing on AI in healthcare, clinical workflow, documentation, and responsible adoption.',
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/writing/', label: 'Writing' },
	{ href: '/about/', label: 'About' },
	{ href: '/contact/', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site">
			<header class="site-header">
				<a class="brand" href="/">
					<span class="brand-mark">HN</span>
					<span>HealthAI Notes</span>
				</a>
				<nav aria-label="Primary">
					<ul class="nav-list">
						{
							navItems.map((item) => (
								<li>
									<a
										href={item.href}
										class:list={{ active: currentPath === item.href }}
										aria-current={currentPath === item.href ? 'page' : undefined}
									>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</header>

			<slot />

			<footer class="site-footer">
				<p>HealthAI Notes is a lightweight publishing site for careful, plain-language analysis.</p>
				<p>Built with Astro and deployed on GitHub Pages.</p>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f5efe4;
		--ink: #16211d;
		--muted: #5e665f;
		--panel: rgba(255, 251, 245, 0.78);
		--line: rgba(22, 33, 29, 0.12);
		--accent: #d66c2f;
		--accent-2: #2f6b5f;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		font-family: Georgia, 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', serif;
		background:
			radial-gradient(circle at top left, rgba(214, 108, 47, 0.22), transparent 34%),
			radial-gradient(circle at right 18%, rgba(47, 107, 95, 0.16), transparent 28%),
			linear-gradient(180deg, #f7f1e7 0%, var(--bg) 100%);
		color: var(--ink);
	}

	a {
		color: inherit;
	}

	.site {
		max-width: 1120px;
		margin: 0 auto;
		padding: 24px 24px 72px;
	}

	.site-header,
	.site-footer,
	.panel {
		backdrop-filter: blur(18px);
		background: var(--panel);
		border: 1px solid var(--line);
		box-shadow: 0 18px 60px rgba(51, 44, 32, 0.08);
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 24px;
		padding: 16px 20px;
		border-radius: 22px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
		font-family: 'Trebuchet MS', 'Segoe UI', sans-serif;
		font-weight: 700;
	}

	.brand-mark {
		display: inline-grid;
		place-items: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 999px;
		background: var(--ink);
		color: #f7f1e7;
		font-size: 0.85rem;
		letter-spacing: 0.06em;
	}

	.nav-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.nav-list a {
		display: inline-block;
		padding: 10px 14px;
		border-radius: 999px;
		text-decoration: none;
		font-family: 'Trebuchet MS', 'Segoe UI', sans-serif;
		font-size: 0.96rem;
	}

	.nav-list a.active {
		background: var(--ink);
		color: #f7f1e7;
	}

	main {
		display: block;
	}

	.page {
		padding: 20px 0 0;
	}

	.hero,
	.card,
	.feature,
	.page-section,
	.article-shell {
		backdrop-filter: blur(18px);
		background: var(--panel);
		border: 1px solid var(--line);
		box-shadow: 0 18px 60px rgba(51, 44, 32, 0.08);
	}

	.hero {
		padding: 48px;
		border-radius: 28px;
	}

	.eyebrow {
		margin: 0 0 12px;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-family: 'Trebuchet MS', 'Segoe UI', sans-serif;
		font-size: 0.78rem;
		color: var(--accent-2);
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 8vw, 6.4rem);
		line-height: 0.92;
	}

	h2 {
		margin: 0 0 12px;
		font-size: 1.6rem;
	}

	p {
		line-height: 1.7;
	}

	.lede,
	.muted {
		color: var(--muted);
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 28px;
	}

	.actions a,
	.button-link {
		text-decoration: none;
		padding: 14px 18px;
		border-radius: 999px;
		font-family: 'Trebuchet MS', 'Segoe UI', sans-serif;
		font-weight: 600;
	}

	.primary {
		background: var(--ink);
		color: #f7f1e7;
	}

	.secondary {
		border: 1px solid var(--line);
		color: var(--ink);
		background: rgba(255, 255, 255, 0.5);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 22px;
	}

	.two-up {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		margin-top: 22px;
	}

	.card,
	.page-section,
	.feature,
	.article-shell {
		padding: 24px;
		border-radius: 24px;
	}

	.article-shell {
		max-width: 820px;
		margin: 0 auto;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 0 0 16px;
		font-family: 'Trebuchet MS', 'Segoe UI', sans-serif;
		font-size: 0.9rem;
		color: var(--muted);
	}

	.prose {
		font-size: 1.06rem;
	}

	.prose h2,
	.prose h3 {
		margin-top: 2rem;
	}

	.prose p,
	.prose li {
		color: var(--ink);
		line-height: 1.8;
	}

	.prose ul {
		padding-left: 1.25rem;
	}

	.prose code {
		padding: 0.15rem 0.35rem;
		border-radius: 0.35rem;
		background: rgba(22, 33, 29, 0.08);
		font-size: 0.95em;
	}

	.prose table {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: 0.98rem;
	}

	.prose th,
	.prose td {
		padding: 0.8rem;
		border-bottom: 1px solid var(--line);
		text-align: left;
		vertical-align: top;
	}

	.card span,
	.kicker {
		display: inline-block;
		font-family: 'Trebuchet MS', 'Segoe UI', sans-serif;
		color: var(--accent);
		font-size: 0.85rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.list {
		margin: 0;
		padding-left: 20px;
		color: var(--muted);
	}

	.site-footer {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		margin-top: 24px;
		padding: 20px 24px;
		border-radius: 22px;
		color: var(--muted);
		font-size: 0.98rem;
	}

	@media (max-width: 900px) {
		.site-header,
		.site-footer,
		.grid,
		.two-up {
			grid-template-columns: 1fr;
			flex-direction: column;
			align-items: flex-start;
		}

		.hero {
			padding: 32px 24px;
		}
	}

	@media (max-width: 640px) {
		.site {
			padding: 16px 16px 48px;
		}

		h1 {
			font-size: clamp(2.5rem, 16vw, 4.2rem);
		}
	}
</style>
